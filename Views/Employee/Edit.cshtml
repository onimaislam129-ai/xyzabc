@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-edit me-2"></i> Edit Employee
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3 p-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Full Name -->
            <div class="mb-3">
                <label asp-for="FullName" class="form-label">
                    <i class="fas fa-id-card me-1"></i> Full Name
                </label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <!-- Phone -->
            <div class="mb-3">
                <label asp-for="Phone" class="form-label">
                    <i class="fas fa-phone me-1"></i> Phone
                </label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <!-- Address -->
            <div class="mb-3">
                <label asp-for="Address" class="form-label">
                    <i class="fas fa-map-marker-alt me-1"></i> Address
                </label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <!-- Position -->
            <div class="mb-3">
                <label asp-for="Position" class="form-label">
                    <i class="fas fa-briefcase me-1"></i> Position
                </label>
                <select asp-for="Position" class="form-select" asp-items="ViewBag.PositionList"></select>
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>

            <!-- Joining Date -->
            <div class="mb-3">
                <label asp-for="JoiningDate" class="form-label">
                    <i class="fas fa-calendar-alt me-1"></i> Joining Date
                </label>
                <input asp-for="JoiningDate" class="form-control" type="date" />
                <span asp-validation-for="JoiningDate" class="text-danger"></span>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="fas fa-save me-1"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card input, .card select {
        border-radius: 6px;
    }

    .card label {
        font-weight: 600;
    }
</style>