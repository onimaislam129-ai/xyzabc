@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger">
            <i class="fas fa-trash-alt me-2"></i> Delete Employee
        </h2>
    </div>

    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this employee? This action cannot be undone.
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-3 mb-4 p-4">
        <dl class="row mb-0">
            <!-- Full Name -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-id-card me-1"></i> Full Name
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.FullName)
            </dd>

            <!-- Phone -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-phone me-1"></i> Phone
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Phone)
            </dd>

            <!-- Address -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-map-marker-alt me-1"></i> Address
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Address)
            </dd>

            <!-- Position -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-briefcase me-1"></i> Position
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Position)
            </dd>

            <!-- Joining Date -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-calendar-alt me-1"></i> Joining Date
            </dt>
            <dd class="col-sm-9">
                @Model.JoiningDate.ToString("dd MMM yyyy")
            </dd>
        </dl>
    </div>

    <form asp-action="Delete" method="post" class="d-flex justify-content-end">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">
            <i class="fas fa-trash-alt me-1"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times me-1"></i> Cancel
        </a>
    </form>
</div>

<style>
    .card dl dt {
        font-weight: 600;
    }

    .card dl dd {
        margin-bottom: 0.75rem;
    }
</style>