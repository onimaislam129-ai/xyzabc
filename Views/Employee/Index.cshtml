@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employees";

    // Pagination values safely retrieved
    int currentPage = ViewData["CurrentPage"] is int cp ? cp : 1;
    int totalPages = ViewData["TotalPages"] is int tp ? tp : 1;
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="fas fa-users me-2"></i> Employees
    </h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus-circle me-1"></i> Add New Employee
    </a>
</div>

<!-- Search Bar -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="d-flex">
        <div class="input-group" style="max-width: 300px;">
            <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm align-middle">
    <thead class="table-light">
        <tr>
            <th><i class="fas fa-id-card me-1"></i> Full Name</th>
            <th><i class="fas fa-phone me-1"></i> Phone</th>
            <th><i class="fas fa-map-marker-alt me-1"></i> Address</th>
            <th><i class="fas fa-briefcase me-1"></i> Position</th>
            <th><i class="fas fa-calendar-alt me-1"></i> Joining Date</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>@item.Position</td>
                <td>@item.JoiningDate.ToString("dd MMM yyyy")</td>
                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">
                        <i class="fas fa-info-circle"></i> Details
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash-alt"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination Controls -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-3">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

<style>
    .table {
        border-radius: 8px;
        overflow: hidden;
    }

    .btn {
        border-radius: 6px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }

    .pagination .page-item .page-link {
        border-radius: 6px;
    }

    .pagination .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }
</style>