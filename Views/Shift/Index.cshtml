@model IEnumerable<EmployeeManagementSystem.Models.Shift>

@{
    ViewData["Title"] = "Shifts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="fas fa-clock me-2"></i> Shift Records
    </h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus-circle me-1"></i> Create New Shift
    </a>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-light">
        <tr>
            <th><i class="fas fa-tag me-1"></i> Name</th>
            <th><i class="fas fa-play-circle me-1"></i> Start Time</th>
            <th><i class="fas fa-stop-circle me-1"></i> End Time</th>
            <th><i class="fas fa-coffee me-1"></i> Break Time</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <td>
                    @{
                        var start = item.StartTime;
                        int startHour = start.Hours % 12;
                        if (startHour == 0) startHour = 12;
                        var startAmPm = start.Hours >= 12 ? "PM" : "AM";
                        var startMinute = start.Minutes.ToString("D2");
                    }
                    @($"{startHour}:{startMinute} {startAmPm}")
                </td>

                <td>
                    @{
                        var end = item.EndTime;
                        int endHour = end.Hours % 12;
                        if (endHour == 0) endHour = 12;
                        var endAmPm = end.Hours >= 12 ? "PM" : "AM";
                        var endMinute = end.Minutes.ToString("D2");
                    }
                    @($"{endHour}:{endMinute} {endAmPm}")
                </td>

                <td>@item.BreakTime</td>

                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">
                        <i class="fas fa-info-circle"></i> Details
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash-alt"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .table {
        border-radius: 8px;
        overflow: hidden;
    }

    .btn {
        border-radius: 6px;
    }
</style>