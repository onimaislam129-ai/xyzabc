@model EmployeeManagementSystem.Models.Shift

@{
    ViewData["Title"] = "Delete Shift";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger">
            <i class="fas fa-trash-alt me-2"></i> Delete Shift
        </h2>
    </div>

    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this record? This action cannot be undone.
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <!-- Shift Name -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-tag me-1"></i> Name
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <!-- Start Time -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-play-circle me-1"></i> Start Time
                </dt>
                <dd class="col-sm-9">
                    @((DateTime.Today + Model.StartTime).ToString("hh:mm tt"))
                </dd>

                <!-- End Time -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-stop-circle me-1"></i> End Time
                </dt>
                <dd class="col-sm-9">
                    @((DateTime.Today + Model.EndTime).ToString("hh:mm tt"))
                </dd>

                <!-- Break Time -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-coffee me-1"></i> Break Time
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.BreakTime)
                </dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="d-flex justify-content-end">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">
            <i class="fas fa-trash-alt me-1"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times me-1"></i> Cancel
        </a>
    </form>
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>