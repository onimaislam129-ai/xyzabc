@model EmployeeManagementSystem.Models.Shift

@{
    ViewData["Title"] = "Shift Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-info-circle me-2"></i> Shift Details
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Shifts
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3 p-4">
        <dl class="row mb-0">
            <!-- Shift Name -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-tag me-1"></i> Name
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Name)
            </dd>

            <!-- Start Time -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-play-circle me-1"></i> Start Time
            </dt>
            <dd class="col-sm-9">
                @((DateTime.Today + Model.StartTime).ToString("hh:mm tt"))
            </dd>

            <!-- End Time -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-stop-circle me-1"></i> End Time
            </dt>
            <dd class="col-sm-9">
                @((DateTime.Today + Model.EndTime).ToString("hh:mm tt"))
            </dd>

            <!-- Break Time -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-coffee me-1"></i> Break Time
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.BreakTime)
            </dd>
        </dl>
    </div>

    <div class="mt-4 d-flex justify-content-end">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary me-2">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
    </div>
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>