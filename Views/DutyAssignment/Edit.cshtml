@model EmployeeManagementSystem.Models.DutyAssignment

@{
    ViewData["Title"] = "Edit Duty Assignment";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-edit me-2"></i> Edit Duty Assignment
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow-lg border-0 rounded-3 p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Employee -->
            <div class="form-floating mb-3">
                <select asp-for="EmployeeId" class="form-select" asp-items="@(ViewData["EmployeeId"] as SelectList)"></select>
                <label asp-for="EmployeeId">
                    <i class="fas fa-user me-1"></i> Employee
                </label>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>

            <!-- Client -->
            <div class="form-floating mb-3">
                <select asp-for="ClientId" class="form-select" asp-items="@(ViewData["ClientId"] as SelectList)"></select>
                <label asp-for="ClientId">
                    <i class="fas fa-building me-1"></i> Client
                </label>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <!-- Shift -->
            <div class="form-floating mb-3">
                <select asp-for="ShiftId" class="form-select" asp-items="@(ViewData["ShiftId"] as SelectList)"></select>
                <label asp-for="ShiftId">
                    <i class="fas fa-clock me-1"></i> Shift
                </label>
                <span asp-validation-for="ShiftId" class="text-danger"></span>
            </div>

            <!-- Date -->
            <div class="form-floating mb-3">
                <input asp-for="Date" class="form-control" type="date" />
                <label asp-for="Date">
                    <i class="fas fa-calendar-alt me-1"></i> Date
                </label>
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <!-- Notes -->
            <div class="form-floating mb-3">
                <textarea asp-for="Notes" class="form-control" style="height:100px;"></textarea>
                <label asp-for="Notes">
                    <i class="fas fa-sticky-note me-1"></i> Notes
                </label>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="fas fa-save me-1"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card label {
        font-weight: 500;
    }

    .btn {
        border-radius: 6px;
    }
</style>