@model EmployeeManagementSystem.Models.DutyAssignment

@{
    ViewData["Title"] = "Delete Duty Assignment";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger">
            <i class="fas fa-trash-alt me-2"></i> Delete Duty Assignment
        </h2>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this record? This action cannot be undone.
        </div>
    </div>

    <!-- Details Card -->
    <div class="card shadow-lg border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 fw-semibold text-secondary"><i class="fas fa-user me-1"></i> Employee</dt>
                <dd class="col-sm-9">@Model.Employee.FullName</dd>

                <dt class="col-sm-3 fw-semibold text-secondary"><i class="fas fa-building me-1"></i> Client</dt>
                <dd class="col-sm-9">@Model.Client.Address</dd>

                <dt class="col-sm-3 fw-semibold text-secondary"><i class="fas fa-clock me-1"></i> Shift</dt>
                <dd class="col-sm-9">@Model.Shift.Name</dd>

                <dt class="col-sm-3 fw-semibold text-secondary"><i class="fas fa-calendar-alt me-1"></i> Date</dt>
                <dd class="col-sm-9">@Model.Date.ToString("dddd, MMMM dd, yyyy")</dd>

                <dt class="col-sm-3 fw-semibold text-secondary"><i class="fas fa-sticky-note me-1"></i> Notes</dt>
                <dd class="col-sm-9">@Model.Notes</dd>
            </dl>
        </div>
    </div>

    <!-- Actions -->
    @if (User.IsInRole("Admin"))
    {
        <form asp-action="Delete" method="post" class="d-flex justify-content-end">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2">
                <i class="fas fa-trash-alt me-1"></i> Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Cancel
            </a>
        </form>
    }
    else
    {
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    }
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>