@model EmployeeManagementSystem.Models.DutyAssignment

@{
    ViewData["Title"] = "Create Duty Assignment";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">
            <i class="fas fa-plus-circle me-2"></i> Create Duty Assignment
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow-lg border-0 rounded-3 p-4">
        @if (User.IsInRole("Admin"))
        {
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Employee Dropdown -->
                <div class="form-group mb-3">
                    <label asp-for="EmployeeId" class="fw-semibold">
                        <i class="fas fa-user me-1"></i> Employee
                    </label>
                    <select asp-for="EmployeeId" class="form-control" asp-items="@(ViewData["EmployeeId"] as SelectList)"></select>
                    <span asp-validation-for="EmployeeId" class="text-danger"></span>
                </div>

                <!-- Client Dropdown -->
                <div class="form-group mb-3">
                    <label asp-for="ClientId" class="fw-semibold">
                        <i class="fas fa-building me-1"></i> Client
                    </label>
                    <select asp-for="ClientId" class="form-control" asp-items="@(ViewData["ClientId"] as SelectList)"></select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <!-- Shift Dropdown -->
                <div class="form-group mb-3">
                    <label asp-for="ShiftId" class="fw-semibold">
                        <i class="fas fa-clock me-1"></i> Shift
                    </label>
                    <select asp-for="ShiftId" class="form-control" asp-items="@(ViewData["ShiftId"] as SelectList)"></select>
                    <span asp-validation-for="ShiftId" class="text-danger"></span>
                </div>

                <!-- Date -->
                <div class="form-group mb-3">
                    <label asp-for="Date" class="fw-semibold">
                        <i class="fas fa-calendar-alt me-1"></i> Date
                    </label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <!-- Notes -->
                <div class="form-group mb-4">
                    <label asp-for="Notes" class="fw-semibold">
                        <i class="fas fa-sticky-note me-1"></i> Notes
                    </label>
                    <textarea asp-for="Notes" class="form-control"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="fas fa-check-circle me-1"></i> Create
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-warning text-center">
                <i class="fas fa-exclamation-triangle me-1"></i> Only Admins can create duty assignments.
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card label {
        font-weight: 600;
    }
</style>