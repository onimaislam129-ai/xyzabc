@model IEnumerable<EmployeeManagementSystem.Models.DutyAssignment>

@{
    ViewData["Title"] = "Duty Assignments";

    // Pagination values safely retrieved
    int currentPage = ViewData["CurrentPage"] is int cp ? cp : 1;
    int totalPages = ViewData["TotalPages"] is int tp ? tp : 1;
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-tasks me-2"></i> Duty Assignments
        </h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus-circle me-1"></i> Create New
            </a>
        }
    </div>

    <!-- Search Bar -->
    <form asp-action="Index" method="get" class="mb-3">
        <div class="d-flex">
            <div class="input-group" style="max-width: 300px;">
                <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search..." />
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </form>

    <!-- Duty Assignments Table -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th><i class="fas fa-user me-1"></i> Employee</th>
                        <th><i class="fas fa-user-tie me-1"></i> Client Name</th> <!-- New column -->
                        <th><i class="fas fa-building me-1"></i> Client Address</th>
                        <th><i class="fas fa-clock me-1"></i> Shift</th>
                        <th><i class="fas fa-calendar-alt me-1"></i> Date</th>
                        <th><i class="fas fa-sticky-note me-1"></i> Notes</th>
                        <th class="text-end"><i class="fas fa-cogs me-1"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Employee.FullName</td>
                            <td>@item.Client.Name</td> <!-- Show Client Name -->
                            <td>@item.Client.Address</td>
                            <td>@item.Shift.Name</td>
                            <td>@item.Date.ToString("dd-MMM-yyyy")</td>
                            <td>@item.Notes</td>
                            <td class="text-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                }

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                                    <i class="fas fa-info-circle"></i> Details
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination Controls -->
            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mt-3">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(currentPage == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
    }

    .btn {
        border-radius: 6px;
    }

    .card {
        border-radius: 8px;
        overflow: hidden;
    }

    .pagination .page-item .page-link {
        border-radius: 6px;
    }

    .pagination .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }
</style>
