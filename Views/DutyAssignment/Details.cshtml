@model EmployeeManagementSystem.Models.DutyAssignment

@{
    ViewData["Title"] = "Duty Assignment Details";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-info-circle me-2"></i> Duty Assignment Details
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <!-- Details Card -->
    <div class="card shadow-lg border-0 rounded-3 p-4">
        <dl class="row mb-0">
            <!-- Employee -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-user me-1"></i> Employee
            </dt>
            <dd class="col-sm-9">@Model.Employee.FullName</dd>

            <!-- Client -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-building me-1"></i> Client
            </dt>
            <dd class="col-sm-9">@Model.Client.Name</dd>

            <!-- Location -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-map-marker-alt me-1"></i> Location
            </dt>
            <dd class="col-sm-9">@Model.Client.Address</dd>

            <!-- Shift -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-clock me-1"></i> Shift
            </dt>
            <dd class="col-sm-9">@Model.Shift.Name</dd>

            <!-- Date -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-calendar-alt me-1"></i> Date
            </dt>
            <dd class="col-sm-9">@Model.Date.ToString("dddd, MMMM dd, yyyy")</dd>

            <!-- Notes -->
            <dt class="col-sm-3 fw-semibold text-secondary">
                <i class="fas fa-sticky-note me-1"></i> Notes
            </dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>

    <!-- Actions -->
    <div class="mt-4 d-flex justify-content-end">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
                <i class="fas fa-edit me-1"></i> Edit
            </a>
        }
    </div>
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>