@model EmployeeManagementSystem.Models.Salary

@{
    ViewData["Title"] = "Create Salary";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">
            <i class="fas fa-plus-circle me-2"></i> Create Salary
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Salaries
        </a>
    </div>

    <!-- Card -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Employee Dropdown -->
                <div class="form-floating mb-3">
                    <select asp-for="EmployeeId" class="form-select"
                            asp-items="@(ViewData["EmployeeId"] as SelectList)">
                        <option value="">-- Select Employee --</option>
                    </select>
                    <label asp-for="EmployeeId">
                        <i class="fas fa-user-tie me-1"></i> Employee
                    </label>
                    <span asp-validation-for="EmployeeId" class="text-danger"></span>
                </div>

                <!-- Month -->
                <div class="form-floating mb-3">
                    <select asp-for="Month" class="form-select">
                        <option value="">Select Month</option>
                        @{
                            for (int i = 1; i <= 12; i++)
                            {
                                var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i);
                                var selected = Model != null && Model.Month == i ? "selected" : null;
                                <option value="@i" selected="@selected">@monthName</option>
                            }
                        }
                    </select>
                    <label asp-for="Month">
                        <i class="fas fa-calendar-alt me-1"></i> Month
                    </label>
                    <span asp-validation-for="Month" class="text-danger"></span>
                </div>

                <!-- Year -->
                <div class="form-floating mb-3">
                    <input asp-for="Year" class="form-control" type="number" min="2000" max="2100" placeholder="Year" />
                    <label asp-for="Year">
                        <i class="fas fa-calendar me-1"></i> Year
                    </label>
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>

                <!-- Info Text -->
                <div class="alert alert-info d-flex align-items-center mb-4">
                    <i class="fas fa-info-circle fa-lg me-2"></i>
                    <div>
                        The <strong>Total Salary</strong> will be calculated automatically
                        based on <strong>shifts and absences</strong>.
                    </div>
                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}