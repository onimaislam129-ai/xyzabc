@model EmployeeManagementSystem.Models.Salary

@{
    ViewData["Title"] = "Edit Salary";
    var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
                 .Where(m => !string.IsNullOrEmpty(m))
                 .Select((name, index) => new { Id = index + 1, Name = name })
                 .ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-edit me-2"></i> Edit Salary
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Salaries
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3 p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Employee Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="EmployeeId" class="fw-semibold">
                    <i class="fas fa-user me-1"></i> Employee
                </label>
                <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId"></select>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>

            <!-- Month Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="Month" class="fw-semibold">
                    <i class="fas fa-calendar-alt me-1"></i> Month
                </label>
                <select asp-for="Month" class="form-select">
                    @foreach (var month in months)
                    {
                        <option value="@month.Id" selected="@(month.Id == Model.Month)">
                            @month.Name
                        </option>
                    }
                </select>
                <span asp-validation-for="Month" class="text-danger"></span>
            </div>

            <!-- Year Input -->
            <div class="form-group mb-4">
                <label asp-for="Year" class="fw-semibold">
                    <i class="fas fa-calendar me-1"></i> Year
                </label>
                <input asp-for="Year" class="form-control" type="number" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="fas fa-save me-1"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .form-group label {
        font-weight: 600;
    }

    .btn {
        border-radius: 6px;
    }
</style>