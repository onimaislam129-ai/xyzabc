@model EmployeeManagementSystem.Models.Salary

@{
    ViewData["Title"] = "Salary Details";
    // Safe conversion with default 0 if null
    var deductionAmount = ViewData["DeductionAmount"] != null ? Convert.ToDecimal(ViewData["DeductionAmount"]) : 0m;
    var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.Month);
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-file-invoice-dollar me-2"></i> Salary Details
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Salaries
        </a>
    </div>

    <!-- Card -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body">
            <h4 class="fw-bold text-dark mb-4">
                <i class="fas fa-user me-2"></i> Employee:
                <span class="text-primary">@Model.Employee.FullName</span>
            </h4>

            <dl class="row mb-0">
                <!-- Month -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-calendar-alt me-1"></i> Month
                </dt>
                <dd class="col-sm-8">@monthName</dd>

                <!-- Year -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-calendar me-1"></i> Year
                </dt>
                <dd class="col-sm-8">@Model.Year</dd>

                <!-- Total Shifts -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-briefcase me-1"></i> Total Shifts
                </dt>
                <dd class="col-sm-8">@Model.TotalShifts</dd>

                <!-- Earnings Before Deduction -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-wallet me-1"></i> Earnings Before Deduction
                </dt>
                <dd class="col-sm-8 text-success fw-bold">
                    @Model.EarningBeforeDeduction.ToString("C")
                </dd>

                <!-- Deduction Amount -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-minus-circle me-1 text-danger"></i> Deduction (Absent Shifts)
                </dt>
                <dd class="col-sm-8 text-danger fw-bold">
                    @deductionAmount.ToString("C")
                </dd>

                <!-- Final Salary -->
                <dt class="col-sm-4 fw-semibold text-secondary">
                    <i class="fas fa-money-bill-wave me-1 text-success"></i> Total Salary (After Deduction)
                </dt>
                <dd class="col-sm-8 text-primary fw-bold fs-5">
                    @Model.TotalSalary.ToString("C")
                </dd>
            </dl>
        </div>
    </div>
</div>