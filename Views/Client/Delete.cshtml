@model EmployeeManagementSystem.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger">
            <i class="fas fa-trash-alt me-2"></i> Delete Client
        </h2>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this record? This action cannot be undone.
        </div>
    </div>

    <!-- Client Info Card -->
    <div class="card shadow-lg border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <!-- Name -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-id-card me-1"></i> Name
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <!-- Address -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-map-marker-alt me-1"></i> Address
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Address)
                </dd>

                <!-- Phone -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-phone-alt me-1"></i> Phone
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Phone)
                </dd>

                <!-- Email -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-envelope me-1"></i> Email
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Email)
                </dd>

                <!-- Type -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-building me-1"></i> Type
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Type)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Delete Form -->
    <form asp-action="Delete" method="post" class="d-flex justify-content-end">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">
            <i class="fas fa-trash-alt me-1"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times me-1"></i> Cancel
        </a>
    </form>
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>