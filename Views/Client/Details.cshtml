@model EmployeeManagementSystem.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-info-circle me-2"></i> Client Details
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Clients
        </a>
    </div>

    <!-- Details Card -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <!-- Name -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-id-card me-1"></i> Name
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <!-- Address -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-map-marker-alt me-1"></i> Address
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Address)
                </dd>

                <!-- Phone -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-phone-alt me-1"></i> Phone
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Phone)
                </dd>

                <!-- Email -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-envelope me-1"></i> Email
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Email)
                </dd>

                <!-- Type -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-building me-1"></i> Type
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Type)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-4 d-flex justify-content-end">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary me-2">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
    </div>
</div>

<style>
    .card dt {
        font-size: 0.95rem;
    }

    .card dd {
        font-size: 1rem;
    }

    .btn {
        border-radius: 6px;
    }
</style>