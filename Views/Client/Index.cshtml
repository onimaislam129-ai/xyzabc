@model IEnumerable<EmployeeManagementSystem.Models.Client>

@{
    ViewData["Title"] = "Clients";

    // Pagination values safely retrieved
    int currentPage = ViewData["CurrentPage"] is int cp ? cp : 1;
    int totalPages = ViewData["TotalPages"] is int tp ? tp : 1;
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-users me-2"></i> Clients
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle me-1"></i> Create New
        </a>
    </div>

    <!-- Search Form -->
    <form asp-action="Index" method="get" class="mb-3 d-flex" style="max-width: 400px;">
        <input type="text" name="searchTerm" value="@searchTerm" class="form-control me-2" placeholder="Search clients..." />
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-search"></i>
        </button>
    </form>

    <!-- Clients Table -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th><i class="fas fa-id-card me-1"></i> @Html.DisplayNameFor(model => model.Name)</th>
                        <th><i class="fas fa-map-marker-alt me-1"></i> @Html.DisplayNameFor(model => model.Address)</th>
                        <th><i class="fas fa-phone-alt me-1"></i> @Html.DisplayNameFor(model => model.Phone)</th>
                        <th><i class="fas fa-envelope me-1"></i> @Html.DisplayNameFor(model => model.Email)</th>
                        <th><i class="fas fa-building me-1"></i> @Html.DisplayNameFor(model => model.Type)</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Address)</td>
                            <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                            <td>@Html.DisplayFor(modelItem => item.Email)</td>
                            <td>@Html.DisplayFor(modelItem => item.Type)</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1 text-white">
                                    <i class="fas fa-info-circle"></i> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination Controls -->
            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mt-3">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(currentPage == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
    }

    .btn {
        border-radius: 6px;
    }

    .pagination .page-item .page-link {
        border-radius: 6px;
    }

    .pagination .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }
</style>