@model EmployeeManagementSystem.Models.Client
@using EmployeeManagementSystem.Models

@{
    ViewData["Title"] = "Edit Client";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-edit me-2"></i> Edit Client
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Clients
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <!-- Name -->
                <div class="form-floating mb-3">
                    <input asp-for="Name" class="form-control" placeholder="Client Name" />
                    <label asp-for="Name"><i class="fas fa-id-card me-1"></i> Name</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Address -->
                <div class="form-floating mb-3">
                    <input asp-for="Address" class="form-control" placeholder="Address" />
                    <label asp-for="Address"><i class="fas fa-map-marker-alt me-1"></i> Address</label>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="form-floating mb-3">
                    <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                    <label asp-for="Phone"><i class="fas fa-phone-alt me-1"></i> Phone</label>
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email (Optional)" />
                    <label asp-for="Email"><i class="fas fa-envelope me-1"></i> Email</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Client Type -->
                <div class="form-floating mb-4">
                    <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<ClientType>()">
                        <option value="">-- Select Client Type --</option>
                    </select>
                    <label asp-for="Type"><i class="fas fa-building me-1"></i> Client Type</label>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .form-floating label i {
        color: #6c757d;
    }

    .btn {
        border-radius: 6px;
    }
</style>