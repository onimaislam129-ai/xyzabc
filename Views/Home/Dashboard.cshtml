@{
    ViewData["Title"] = "Dashboard";
    var role = ViewData["Role"]?.ToString();
}

<div class="container mt-5">
    <h2 class="mb-4">Welcome, @role!</h2>
    <p class="text-muted mb-5">Select a module below to get started:</p>

    <div class="row g-4">
        @if (role == "Admin")
        {
            @* Admin Grid: 6 equal cards including Attendance *@
            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-users display-4 text-primary mb-3"></i>
                        <h5 class="card-title">Employee Management</h5>
                        <p class="card-text">Manage employee records and details.</p>
                        <a asp-controller="Employee" asp-action="Index" class="btn btn-primary">Go</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-calendar-check display-4 text-success mb-3"></i>
                        <h5 class="card-title">Attendance</h5>
                        <p class="card-text">Take and manage attendance records.</p>
                        <a asp-controller="Attendance" asp-action="Index" class="btn btn-success">Go</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-clock display-4 text-warning mb-3"></i>
                        <h5 class="card-title">Shift Management</h5>
                        <p class="card-text">Create and organize employee shifts.</p>
                        <a asp-controller="Shift" asp-action="Index" class="btn btn-warning">Go</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-building display-4 text-info mb-3"></i>
                        <h5 class="card-title">Clients</h5>
                        <p class="card-text">Manage client information and contracts.</p>
                        <a asp-controller="Client" asp-action="Index" class="btn btn-info">Go</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-money-bill-wave display-4 text-danger mb-3"></i>
                        <h5 class="card-title">Salary</h5>
                        <p class="card-text">Manage and process salaries.</p>
                        <a asp-controller="Salary" asp-action="Index" class="btn btn-danger">Go</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-shield-alt display-4 text-secondary mb-3"></i>
                        <h5 class="card-title">Duty Assignment</h5>
                        <p class="card-text">Assign guards to clients or events.</p>
                        <a asp-controller="DutyAssignment" asp-action="Index" class="btn btn-secondary">Go</a>
                    </div>
                </div>
            </div>
        }
        else if (role == "Guard")
        {
            @* Guard: 2 larger cards *@
            <div class="col-md-6">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-shield-alt display-3 text-secondary mb-3"></i>
                        <h4 class="card-title">Duty Assignment</h4>
                        <p class="card-text">View your duty assignments and schedules.</p>
                        <a asp-controller="DutyAssignment" asp-action="Index" class="btn btn-secondary btn-lg">View</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card dashboard-card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="fas fa-money-bill-wave display-3 text-danger mb-3"></i>
                        <h4 class="card-title">Salary</h4>
                        <p class="card-text">Check your salary records and history.</p>
                        <a asp-controller="Salary" asp-action="Index" class="btn btn-danger btn-lg">View</a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                You don’t have access to the dashboard. Please contact the administrator.
            </div>
        }
    </div>
</div>

<style>
    .dashboard-card {
        border-radius: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .dashboard-card .card-body i {
            transition: transform 0.2s;
        }

        .dashboard-card:hover .card-body i {
            transform: scale(1.1);
        }
</style>