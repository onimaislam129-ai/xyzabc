@model EmployeeManagementSystem.Models.Attendance

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="fas fa-info-circle me-2"></i> Attendance Details
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <!-- Employee -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-user me-1"></i> Employee
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Employee.FullName)
                </dd>

                <!-- Date -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-calendar-day me-1"></i> Date
                </dt>
                <dd class="col-sm-9">
                    @Model.Date.ToString("dd MMM yyyy")
                </dd>

                <!-- Status -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-clipboard-check me-1"></i> Status
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Status)
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-end">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary me-2">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
    </div>
</div>