@model EmployeeManagementSystem.Models.Attendance

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger">
            <i class="fas fa-trash-alt me-2"></i> Delete Attendance
        </h2>
    </div>

    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-2"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this record? This action cannot be undone.
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <!-- Employee -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-user me-1"></i> Employee
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Employee.FullName)
                </dd>

                <!-- Date -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-calendar-day me-1"></i> Date
                </dt>
                <dd class="col-sm-9">
                    @Model.Date.ToString("dd MMM yyyy")
                </dd>

                <!-- Status -->
                <dt class="col-sm-3 fw-semibold text-secondary">
                    <i class="fas fa-clipboard-check me-1"></i> Status
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Status)
                </dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="d-flex justify-content-end">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">
            <i class="fas fa-trash-alt me-1"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-times me-1"></i> Cancel
        </a>
    </form>
</div>