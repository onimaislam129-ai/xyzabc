@model IEnumerable<EmployeeManagementSystem.Models.Attendance>

@{
    ViewData["Title"] = "Attendance";
    var isAdmin = User.IsInRole("Admin");

    int currentPage = ViewData["CurrentPage"] != null ? Convert.ToInt32(ViewData["CurrentPage"]) : 1;
    int totalPages = ViewData["TotalPages"] != null ? Convert.ToInt32(ViewData["TotalPages"]) : 1;
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="fas fa-calendar-check me-2"></i> Attendance Records
    </h2>

    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle me-1"></i> Take Attendance
        </a>
    }
</div>

<!-- Search Form -->
<form asp-action="Index" method="get" class="mb-3 d-flex" style="max-width: 400px;">
    <input type="text" name="searchTerm" value="@searchTerm" class="form-control me-2" placeholder="Search by Employee or Status..." />
    <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i>
    </button>
</form>

@if (isAdmin)
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-light">
            <tr>
                <th><i class="fas fa-user me-1"></i> Employee</th>
                <th><i class="fas fa-calendar-day me-1"></i> Date</th>
                <th><i class="fas fa-clipboard-check me-1"></i> Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Employee.FullName</td>
                    <td>@item.Date.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (item.Status == EmployeeManagementSystem.Models.AttendanceStatus.Present)
                        {
                            <span class="badge bg-success">
                                <i class="fas fa-check-circle me-1"></i> Present
                            </span>
                        }
                        else if (item.Status == EmployeeManagementSystem.Models.AttendanceStatus.Absent)
                        {
                            <span class="badge bg-danger">
                                <i class="fas fa-times-circle me-1"></i> Absent
                            </span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">
                            <i class="fas fa-info-circle"></i> Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash-alt"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination Controls -->
    <nav aria-label="Attendance pagination">
        <ul class="pagination justify-content-center mt-3">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
else
{
    <div class="alert alert-warning mt-4">
        <i class="fas fa-exclamation-triangle me-1"></i>
        You do not have permission to view attendance records.
    </div>
}

<style>
    .table {
        border-radius: 8px;
        overflow: hidden;
    }

    .btn {
        border-radius: 6px;
    }

    .pagination .page-item .page-link {
        border-radius: 6px;
    }
</style>